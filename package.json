{
  "name": "can-claude-profile",
  "version": "1.0.0",
  "description": "One-command capture and restore of a personal Claude Code setup (skills, plugins, MCP, settings), with Microsoft items filtered out.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangcansunking/can-claude-profile.git"
  },
  "bin": {
    "can-claude-profile": "profile.mjs"
  },
  "files": [
    "profile.mjs",
    "lib/",
    "profile/",
    "filter.config.json"
  ],
  "scripts": {
    "sync": "node profile.mjs sync",
    "install-profile": "node profile.mjs install",
    "test": "node test/merge.unit.mjs",
    "test:e2e": "bash test/e2e/run.sh",
    "test:e2e:online": "bash test/e2e/run.sh --online"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
